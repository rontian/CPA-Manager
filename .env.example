# CPA-Manager (Usage Service & Control Panel host) configurations

# Host port mapping for CPA-Manager panel and usage API
CPA_MANAGER_PORT=18317

# Listening address inside the container
HTTP_ADDR=0.0.0.0:18317

# Host directory mapping for persistent SQLite database
CPA_MANAGER_DATA_DIR=./data

# SQLite database directory and path inside the container
USAGE_DATA_DIR=/data
USAGE_DB_PATH=/data/usage.sqlite

# Upstream CLIProxyAPI server URL (e.g. http://cli-proxy-api:8317 or http://host.docker.internal:8317)
# Note: If running on the same docker network, you can use the service name of CLIProxyAPI.
CPA_UPSTREAM_URL=

# Management key configured on CLIProxyAPI (remote-management.secret-key plaintext value)
CPA_MANAGEMENT_KEY=

# Usage collection configuration
USAGE_COLLECTOR_MODE=auto
USAGE_RESP_QUEUE=usage
USAGE_RESP_POP_SIDE=right
USAGE_BATCH_SIZE=100
USAGE_POLL_INTERVAL_MS=500
USAGE_QUERY_LIMIT=50000

# CORS settings
USAGE_CORS_ORIGINS=*

# Build arguments (Optional)
# VERSION=v2.4.1
